---
import "../styles/global.css"
---


    <div class="container mx-auto p-6 md:p-10">


        <section id="existing-components" class="bg-white p-8 rounded-lg shadow-lg">
            <h2 class="text-3xl font-semibold text-gray-800 mb-6 border-b pb-4">Existing Components</h2>
            <p class="text-gray-700 mb-6">Browse the list below to see available components and their usage instructions.</p>

            <div class="component-card border border-gray-200 rounded-lg p-6 mb-6">
                <h3 class="text-2xl font-bold text-blue-700 mb-3">PrimaryButton</h3>
                <p class="text-gray-700 mb-4">A standard primary action button for general use across the application.</p>

                <div class="mb-4">
                    <h4 class="text-xl font-semibold text-gray-800 mb-2">Usage:</h4>
                    <pre><code>import &#123; PrimaryButton &#125; from '../components/buttons';

&lt;PrimaryButton text="Save Changes" onClick=&#123;handleSave&#125; /&gt;
&lt;PrimaryButton text="Disabled Button" disabled /&gt;</code></pre>
                </div>

                <div class="mb-4">
                    <h4 class="text-xl font-semibold text-gray-800 mb-2">Props / API:</h4>
                    <ul class="list-disc list-inside text-gray-700">
                        <li><code class="font-bold">text</code>: <span class="text-purple-600">string</span> (required) - The visible label of the button.</li>
                        <li><code class="font-bold">onClick</code>: <span class="text-purple-600">function</span> (optional) - Callback function executed when the button is clicked.</li>
                        <li><code class="font-bold">disabled</code>: <span class="text-purple-600">boolean</span> (default: `false`) - If true, the button will be disabled and unclickable.</li>
                        <li><code class="font-bold">variant</code>: <span class="text-purple-600">'primary' | 'secondary' | 'ghost'</span> (default: `'primary'`) - Visual style of the button.</li>
                    </ul>
                </div>

                <div class="mb-4">
                    <h4 class="text-xl font-semibold text-gray-800 mb-2">Dependencies:</h4>
                    <span class="bg-gray-200 text-gray-700 text-sm px-3 py-1 rounded-full">None</span>
                </div>

                <div class="text-sm text-gray-600">
                    <p><strong>Owner:</strong> Jane Doe (@janedoe)</p>
                    <p><strong>Status:</strong> Stable</p>
                </div>
            </div>

            <div class="component-card border border-gray-200 rounded-lg p-6 mb-6">
                <h3 class="text-2xl font-bold text-blue-700 mb-3">UserAvatar</h3>
                <p class="text-gray-700 mb-4">Displays a user's avatar image, falling back to initials if no image is provided.</p>

                <div class="mb-4">
                    <h4 class="text-xl font-semibold text-gray-800 mb-2">Usage:</h4>
                    <pre><code>import &#123; UserAvatar &#125; from '../components/user';

&lt;UserAvatar imageUrl="https://example.com/avatar.jpg" altText="John Doe" size="medium" /&gt;
&lt;UserAvatar name="Jane Smith" size="small" /&gt;</code></pre>
                </div>

                <div class="mb-4">
                    <h4 class="text-xl font-semibold text-gray-800 mb-2">Props / API:</h4>
                    <ul class="list-disc list-inside text-gray-700">
                        <li><code class="font-bold">imageUrl</code>: <span class="text-purple-600">string</span> (optional) - URL of the user's avatar image.</li>
                        <li><code class="font-bold">altText</code>: <span class="text-purple-600">string</span> (optional) - Alt text for the image, important for accessibility.</li>
                        <li><code class="font-bold">name</code>: <span class="text-purple-600">string</span> (optional) - User's full name, used for fallback initials.</li>
                        <li><code class="font-bold">size</code>: <span class="text-purple-600">'small' | 'medium' | 'large'</span> (default: `'medium'`) - Predefined sizes for the avatar.</li>
                    </ul>
                </div>

                <div class="mb-4">
                    <h4 class="text-xl font-semibold text-gray-800 mb-2">Dependencies:</h4>
                    <span class="bg-gray-200 text-gray-700 text-sm px-3 py-1 rounded-full">None</span>
                </div>

                <div class="text-sm text-gray-600">
                    <p><strong>Owner:</strong> Alex Chen (@alexchen)</p>
                    <p><strong>Status:</strong> Stable</p>
                </div>
            </div>

            </section>


    </div>

