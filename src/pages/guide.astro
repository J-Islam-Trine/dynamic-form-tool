---


import "../styles/global.css";
//Layouts
import MainLayout from "../components/layouts/mainLayout.astro";

//components
import { Code } from 'astro:components';
import CompDescCards from "../components/components/compDescCards.astro";
import Card from "../components/layouts/card.astro";

//data
import {def as MainLayoutDef}  from "../data/componentDefinitions/describeMainLayout.js";

---
<MainLayout>
    <div class="p-4">
        <h1 class="font-bold text-4xl">Guide</h1>

        <div class="border-2 my-4 p-4 bg-blue-100">
            <p class="text-xl font-semibold py-2">How add a new component?</p>

            <div>
                <p class="font-bold">Add a new component description</p>
                <ul>
                    <li>1. Go to <span class="font-semibold">src/data/componentDefinitions</span>.</li>
                    <li>2. Create a new file with the name of the component as <span class="font-semibold">describe[Put Component Name Here].js</span></li>
                    <li>3. Inside the file, create a new variable named <span class="font-semibold">def</span> with the following format:
                    </li>
                </ul>
                <Code class="p-2" code={`export const def ={
                    name: "MainLayout",
                    type: "Layout",
                    description: "Layout for pages when user is logged in.",
                    props: [
                        {
                            name: "username", //name of the props
                            description: "Username of the logged in user.", //description
                            type: "string", //type
                            required: true,
                            defaultValue: ""
                        },
                        {
                            name: "role",
                            description: "Role of the logged in user.",
                            type: "string",
                            required: true,
                            defaultValue: ""
                        },
                    ],
                }`} lang="js" />
            
            </div>
        </div>
    
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <CompDescCards name={MainLayoutDef.name} type={MainLayoutDef.type} description={MainLayoutDef.description} props={MainLayoutDef.props} />
    </div>
</MainLayout>