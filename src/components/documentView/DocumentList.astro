---
interface Document {
  filename: string;
  title: string;
  date: string;
}

interface Props {
  documents: Document[];
  currentDocument?: string;
}

const { documents, currentDocument } = Astro.props;
---

<div class="sidebar">
  <div class="sidebar-header">
    <h1>Documents</h1>
    <p class="document-count">You have {documents.length} documents</p>
  </div>

  <div class="document-group">
    <div class="group-header">
      <h2>Campaign</h2>
      <p class="document-meta">Read the document and see what we do</p>
    </div>

    <div class="document-items">
      {documents.map((doc) => (
        <a 
          class={document-item ${currentDocument === doc.filename ? 'active' : ''}}
          href={?document=${doc.filename}}
        >
          <h3>{doc.title}</h3>
          <p class="document-meta">Sipilway Delicious - {doc.date}</p>
        </a>
      ))}
    </div>
  </div>
</div>


<style>
  .sidebar {
    width: 280px;
    padding: 20px 15px;
    background: #f8f8f8;
    height: 100vh;
    overflow-y: auto;
    border-right: 1px solid #e1e1e1;
    font-family: 'Segoe UI', Arial, sans-serif;
  }

  .sidebar-header {
    margin-bottom: 25px;
  }

  .sidebar h1 {
    font-size: 20px;
    font-weight: 600;
    margin: 0 0 5px 0;
    color: #333;
  }

  .document-count {
    font-size: 13px;
    color: #666;
    margin: 0;
  }

  .document-group {
    margin-bottom: 25px;
  }

  .group-header h2 {
    font-size: 15px;
    font-weight: 500;
    margin: 0 0 3px 0;
    color: #333;
  }

  .document-meta {
    font-size: 12px;
    color: #888;
    margin: 0;
  }

  .document-items {
    margin-top: 10px;
  }

  .document-item {
    display: block;
    padding: 8px 0;
    border-bottom: 1px solid #eee;
    color: inherit;
    text-decoration: none;
    cursor: pointer;
  }

  .document-item:hover {
    background-color: #f0f0f0;
  }

  .document-item.active {
    background-color: #e0e0e0;
  }

  .document-item h3 {
    font-size: 14px;
    font-weight: 400;
    margin: 0 0 2px 0;
    color: #444;
  }

  @media (max-width: 768px) {
    .sidebar {
      width: 100%;
      height: auto;
      max-height: 300px;
      border-right: none;
      border-bottom: 1px solid #e1e1e1;
    }
  }
</style>