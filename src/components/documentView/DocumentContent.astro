---
interface ClientInfo {
  name: string;
  number: string;
}

interface Props {
  document?: {
    filename: string;
    title: string;
    date: string;
  };
  clientInfo?: ClientInfo;
}

const { document: activeDocument, clientInfo } = Astro.props;
---

<div class="content">
  {activeDocument ? (
    <div class="document-view">
      <div class="pdf-container">
        <iframe
          src={/pdf/${activeDocument.filename}#toolbar=0}
          class="pdf-viewer"
          frameborder="0"
        ></iframe>
      </div>

      <div class="document-actions">
        <span class="thank-you">Thank you!</span>
        <span class="page-count">1 of 32</span>
      </div>
    </div>
  ) : (
    <p>No document selected</p>
  )}
</div>

<style>
  .content {
    flex: 1;
    padding: 20px;
    background: #fff;
  }
  .pdf-container {
    height: 100vh;
    border: 1px solid #ccc;
    margin-top: 20px;
  }
  .pdf-viewer {
    width: 100%;
    height: 100%;
  }
</style>

