---
import { Icon } from "astro-icon/components";
const {selected=false, options=[], label="", placeholder="", type="text", typeClass="input", icon="mdi:email", active=false} = Astro.props;
---

<div class="flex flex-col w-full">
    <span>{label}</span>
    <div class="join">
        <span class="btn join-item"
            ><Icon class="text-2xl" name={icon} /></span
        >
        {(type === 'select')? (
            <select class={`select ${typeClass}`} disabled={active}>
                  {options?.map((option) => (
                    <option
                      value={option.value}
                      disabled={active}
                      selected={option.selected}
                    >
                      {option.label}
                    </option>
                  ))}
                </select>
        ):
        (
            <input
                class={`join-item ${typeClass} w-full`}
                type={type}
                placeholder={placeholder}
                disabled={active}
            />
        )
        }
    </div>
</div>
