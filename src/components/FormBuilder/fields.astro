---
import { Icon } from "astro-icon/components";


const {buttonStyle, fieldData} = Astro.props;
---
<div class="flex flex-col gap-2">
    {fieldData.map((data)=>(
        <div>
            <span class="font-medium">{data.title}</span>
        </div>
        <div class="flex flex-col gap-1">
        {data.ButtonData.map((btn)=>(
            <div class={`w-full ${buttonStyle} flex flex-row items-center justify-between`}>
                <span> {btn.name} </span>
                <Icon name="mdi:plus-circle-outline" class="text-xl" />
            </div>
        ))}
        </div>
        
    ))}

</div>
