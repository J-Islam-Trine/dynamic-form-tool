---
import Alert from "../shared/alert.astro";
import Breadcrumbs from "../shared/breadcrumbs.astro";
import Toggle from "../shared/toggle.astro";


const {breadcrumbs} = Astro.props;
---
<div class="flex flex-col md:flex-row justify-between items-center md:h-10 my-5">
    <Breadcrumbs breadcrumbs = {breadcrumbs}/>
    <Toggle/>
    <Alert/>
</div>