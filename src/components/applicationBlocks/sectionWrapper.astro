---
const { title, sectionData } = Astro.props;
---
<div class="flex flex-col gap-5 py-10">
    <div class=" bg-blue-400 px-5 py-2 rounded-lg">
        <span class="text-xl font-semibold text-white">{title}</span>
    </div>
    <div class="flex flex-row flex-wrap gap-x-7 gap-y-3">
         {sectionData.content.map((item) => (
          <div class="flex flex-row gap-3 items-center p-2">
            <span class="font-medium text-wrap">{item.label}</span>
            <span class="p-2 border-2 border-slate-200  min-w-25 text-center">{item.value}</span>
          </div>
        ))}
    </div>
</div>