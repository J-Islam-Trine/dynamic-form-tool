---
const {label, value, bodyStyle, labelStyle, valueStyle} = Astro.props;
---

<div class=`flex flex-row gap-2 md:items-center ${bodyStyle}`>
    <span class=`font-medium ${labelStyle}`>{label}</span>
    <span class=`p-2 text-center rounded-sm ${valueStyle} border-gray-200`>
        {value}
    </span>
</div>
