---
const { username="Jane Doe", role="Admin", avatarImageUrl="https://i.pravatar.cc/150?img=52" } = Astro.props;

import '../../styles/global.css';

import { Icon } from "astro-icon/components";
import Navbar from '../../components/shared/navbar.astro';
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Responsive Sidebar</title>
</head>
<body class="h-screen">
  <!-- Top Navbar -->
  <header class="sticky top-0 z-20">
    <Navbar userName={username} role={role} avatarImageUrl={avatarImageUrl}/>
  </header>

      <!-- Main Page Content -->
      <main class="grid grid-cols-1 md:grid-cols-[250px_1fr] gap-1">
        <div>
            <slot name="sidebar"/>
        </div>
        <div class="overflow-x-auto">
          <!-- <h1>Back Office Dashboard</h1> -->

            <slot name="content"/>


        </div>
 
      </main>
    </div>

  </div>
 

<!-- Open the modal using ID.showModal() method -->
{
role == "Relationship Officer" && 
<button class="btn sticky bg-gray-200 z-999 bottom-5 left-10 border-4 border-black absolute w-20 h-20 rounded-full" onclick="my_modal_1.showModal()">
  <Icon name="mdi:add" class="w-10 h-10" /> 
</button>
<dialog id="my_modal_1" class="modal">
  <div class="modal-box w-3/4">
    <h3 class="text-lg font-bold">Create new application</h3>
    <p class="py-4"></p>
    <div class="grid grid-cols-2 gap-2">
      <a class="" href="/applications/create/demographic">
        <button class="btn btn-soft btn-primary text-xl w-full">
          SME
        </button>
      </a>

      <a class="" href="/applications/create/creditCard">
        <button class="btn btn-soft text-xl w-full">
          Credit Card
        </button>
      </a>
      <a class="" href="/applications/create/salaryAdvance">
        <button class="btn btn-soft text-xl w-full">
          Salary Advance
        </button>
      </a>
      <a class="" href="/applications/create/twoWheelerLoan">
        <button class="btn btn-soft btn-secondary text-xl w-full">
          Two Wheeler Loan
        </button>
      </a>
    </div>
    <div class="modal-action">
      <form method="dialog">

        <!-- if there is a button in form, it will close the modal -->
        <button class="btn">Close</button>
      </form>
    </div>
  </div>
</dialog>
}

</body>
</html>
