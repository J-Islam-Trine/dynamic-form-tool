---
import "../../styles/global.css"
//components
import TwoColumnsFullWidth from "../twoColumnsFullWidth.astro";

const {name, label, checked} = Astro.props
---

<input type="radio" name={name} class="tab checked:[--tab-bg:lightblue] text-white" aria-label={label} checked={checked}/>
<div class="tab-content p-4">
    <TwoColumnsFullWidth>
        <slot />
    </TwoColumnsFullWidth>
</div>