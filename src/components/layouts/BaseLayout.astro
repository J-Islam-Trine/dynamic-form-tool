---
const { title } = Astro.props;
---

<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-gray-100">
    <main class="container mx-auto p-4">
      <slot />
    </main>
  </body>
</html>
