---
const {title, content} = Astro.props;
---
<div class="flex flex-col gap-5 h-full rounded-xl p-2">
    <span class="font-semibold border-b-2 border-slate-300 pb-2">{title}</span>
    <div>
        {content.map((con)=> (
            <div class="grid grid-cols-2">
                <span class="font-semibold">{con.label}</span>
                <span>{con.value}</span>
            </div>
        ))}
    </div>
</div>