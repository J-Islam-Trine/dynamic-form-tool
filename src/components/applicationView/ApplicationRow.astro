---
const { app } = Astro.props;
---

<tr class="row-line">
  <td>{app.id}</td>
  <td>{app.userName}</td>
  <td>{app.loanType}</td>
  <td>{app.branch}</td>
  <td>{app.date}</td>
  <td>
    <div class={`status-label ${app.status.toLowerCase().replace(/\s/g, "-")}`}>
      {app.status}
    </div>
  </td>
</tr>

<style>
  .row-line td {
    padding: 12px 16px;
    border-bottom: 1px solid #dadada;
  }

  .status-label {
    display: inline-block;
    font-weight: 600;
    padding: 2px 6px;
    border-radius: 4px;
  }

  .status-label.complete {
    color: green;
  }

  .status-label.in-progress {
    color: dodgerblue;
  }

  .status-label.pending {
    color: orange;
  }

  .status-label.rejected {
    color: red;
  }

  .status-label::before,
  .status-label::marker {
    content: none;
  }
</style>
