---
import "../../styles/global.css"

const {name="", type="", description="", props=[]} = Astro.props;
---

<div class="w-full">
    <div class="card shadow-md border-1">
        <div class="card-body p-4">
            <h2 class="font-bold text-2xl">{name}</h2>
            <h3 class="text-xl">Type: <span class="font-bold">{type}</span></h3>
            <p class="text-lg py-2">{description}</p>
            <ul>
                {props.map((prop: any) => (
                    <li><span class="font-bold">{prop.name}[{prop.type}]:</span> {prop.description}</li>
                ))}
            </ul>

</div>
</div>
</div>