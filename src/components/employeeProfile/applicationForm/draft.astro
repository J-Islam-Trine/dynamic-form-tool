---
---

<div class="max-w-4xl mx-auto mt-8 bg-white shadow-md rounded-lg p-6 space-y-6">
    <h2 class="text-2xl font-bold text-gray-800">Send Application</h2>

    <form method="POST" class="space-y-4">
      <div>
        <label class="label">
          <span class="label-text font-medium">To</span>
        </label>
        <input type="email" placeholder="recipient@bank.com" class="input input-bordered w-full" required />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="label">
            <span class="label-text font-medium">CC</span>
          </label>
          <input type="email" placeholder="cc@example.com" class="input input-bordered w-full" />
        </div>

        <div>
          <label class="label">
            <span class="label-text font-medium">BCC</span>
          </label>
          <input type="email" placeholder="bcc@example.com" class="input input-bordered w-full" />
        </div>
      </div>

      <div>
        <label class="label">
          <span class="label-text font-medium">Subject</span>
        </label>
        <input type="text" placeholder="Subject of your application" class="input input-bordered w-full" required />
      </div>

      <div>
        <label class="label">
          <span class="label-text font-medium">Message</span>
        </label>
        <textarea placeholder="Write your application here..." class="textarea textarea-bordered w-full h-40" required></textarea>
      </div>

      <div class="flex justify-end gap-4 pt-4">
        <button type="button" class="btn btn-outline btn-warning">Save as Draft</button>
        <button type="submit" class="btn btn-primary">Submit Application</button>
      </div>
    </form>
  </div>